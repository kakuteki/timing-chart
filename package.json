{
  "name": "timing-chart",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "FPGA/embedded timing chart (waveform) editor — client-side, WaveDrom-based",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "bridge": "node bridge/server.mjs",
    "test": "node --test test/bridge.test.mjs test/render.test.mjs",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "lz-string": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wavedrom": "^3.5.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
